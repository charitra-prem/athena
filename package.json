{
  "name": "athena",
  "private": true,
  "type": "module",
  "scripts": {
    "build:agent": "bun build agent.ts --outfile=.build/agent.js --target=node --format=esm --external '*'",
    "bootstrap": "bun run build:agent && tsx --env-file=.env bootstrap.ts",
    "predeploy": "bun run build:agent",
    "deploy": "vercel deploy --prod --yes",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/backend": "^1.34.0",
    "@vercel/blob": "^2.4.0",
    "@vercel/functions": "^3.6.0",
    "@vercel/sandbox": "^1.10.2",
    "ms": "^2.1.3",
    "svix": "^1.94.0"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@types/node": "^22.10.0",
    "@vercel/node": "^5.8.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
